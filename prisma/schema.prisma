// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVO
  INACTIVO
  BLOQUEADO
}

enum GenericStatus {
  ACTIVO
  INACTIVO
}

enum TipoDocumento {
  CC
  CE
  TI
  RC
  PASAPORTE
  NIT
  OTRO
}

enum ContratoTipo {
  EPS
  PARTICULAR
  OTRO
}

enum TipoCobro {
  CUOTA_MODERADORA
  PARTICULAR
}

enum JornadaCajaEstado {
  ABIERTA
  CERRADA
  REABIERTA
}

enum SesionOperativaEstado {
  ACTIVA
  CERRADA
}

enum AdmisionEstado {
  REGISTRADA
  ANULADA
}

enum DescuentoTipo {
  NINGUNO
  PORCENTAJE
  VALOR_FIJO
}

enum MovimientoTipo {
  COBRO
  DEVOLUCION
  REVERSO_ANULACION
}

enum MovimientoNaturaleza {
  ENTRADA
  SALIDA
}

enum MetodoPago {
  EFECTIVO
  NEQUI
  DAVIPLATA
  TRANSFERENCIA
  TARJETA
  OTRO
}

model Rol {
  id          Int           @id @default(autoincrement())
  nombre      String        @unique
  descripcion String?
  estado      GenericStatus @default(ACTIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  usuarios Usuario[]
  permisos RolPermiso[]
}

model Permiso {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  moduloSistema String
  descripcion   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles RolPermiso[]
}

model RolPermiso {
  id        Int @id @default(autoincrement())
  rolId     Int
  permisoId Int

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
}

model Usuario {
  id              Int           @id @default(autoincrement())
  tipoDocumento   TipoDocumento
  numeroDocumento String        @unique
  primerNombre    String
  segundoNombre   String?
  primerApellido  String
  segundoApellido String?
  telefono        String?
  email           String?       @unique
  username        String        @unique
  passwordHash    String
  estado          UserStatus    @default(ACTIVO)
  rolId           Int
  authUserId      String?       @unique
  ultimoLoginAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rol                   Rol               @relation(fields: [rolId], references: [id])
  authUser              User?             @relation(fields: [authUserId], references: [id], onDelete: SetNull)
  jornadasAbiertas      JornadaCaja[]     @relation("JornadaCajaAbiertaPor")
  jornadasCerradas      JornadaCaja[]     @relation("JornadaCajaCerradaPor")
  jornadasReabiertas    JornadaCaja[]     @relation("JornadaCajaReabiertaPor")
  sesionesOperativas    SesionOperativa[]
  admisionesRegistradas Admision[]        @relation("AdmisionRegistradaPor")
  admisionesAnuladas    Admision[]        @relation("AdmisionAnuladaPor")
  movimientos           Movimiento[]
  auditorias            Auditoria[]
}

model Paciente {
  id              Int           @id @default(autoincrement())
  tipoDocumento   TipoDocumento
  numeroDocumento String        @unique
  primerNombre    String
  segundoNombre   String?
  primerApellido  String
  segundoApellido String?
  telefono        String?
  estado          GenericStatus @default(ACTIVO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  admisiones Admision[]
}

model Contrato {
  id          Int           @id @default(autoincrement())
  nombre      String        @unique
  tipo        ContratoTipo
  descripcion String?
  estado      GenericStatus @default(ACTIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  categorias ContratoCategoriaAfiliacion[]
  tarifas    TarifaServicio[]
  admisiones Admision[]
}

model CategoriaAfiliacion {
  id          Int           @id @default(autoincrement())
  codigo      String        @unique
  nombre      String
  descripcion String?
  estado      GenericStatus @default(ACTIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contratos  ContratoCategoriaAfiliacion[]
  tarifas    TarifaServicio[]
  admisiones Admision[]
}

model ContratoCategoriaAfiliacion {
  id                    Int           @id @default(autoincrement())
  contratoId            Int
  categoriaAfiliacionId Int
  estado                GenericStatus @default(ACTIVO)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  contrato            Contrato            @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  categoriaAfiliacion CategoriaAfiliacion @relation(fields: [categoriaAfiliacionId], references: [id], onDelete: Cascade)

  @@unique([contratoId, categoriaAfiliacionId])
}

model Servicio {
  id          Int           @id @default(autoincrement())
  codigo      String?       @unique
  nombre      String        @unique
  descripcion String?
  estado      GenericStatus @default(ACTIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tarifas    TarifaServicio[]
  admisiones Admision[]
}

model TarifaServicio {
  id                    Int           @id @default(autoincrement())
  servicioId            Int
  contratoId            Int
  categoriaAfiliacionId Int?
  tipoCobro             TipoCobro
  valor                 Decimal       @db.Decimal(12, 2)
  fechaInicioVigencia   DateTime
  fechaFinVigencia      DateTime?
  estado                GenericStatus @default(ACTIVO)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  servicio            Servicio             @relation(fields: [servicioId], references: [id])
  contrato            Contrato             @relation(fields: [contratoId], references: [id])
  categoriaAfiliacion CategoriaAfiliacion? @relation(fields: [categoriaAfiliacionId], references: [id])

  admisiones Admision[]
}

model Piso {
  id          Int           @id @default(autoincrement())
  nombre      String        @unique
  descripcion String?
  estado      GenericStatus @default(ACTIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  modulos     ModuloAtencion[]
  cajas       Caja[]
  sesiones    SesionOperativa[]
  admisiones  Admision[]
  movimientos Movimiento[]
}

model ModuloAtencion {
  id        Int           @id @default(autoincrement())
  nombre    String
  codigo    String        @unique
  pisoId    Int
  estado    GenericStatus @default(ACTIVO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  piso        Piso              @relation(fields: [pisoId], references: [id])
  sesiones    SesionOperativa[]
  admisiones  Admision[]
  movimientos Movimiento[]

  @@unique([nombre, pisoId])
}

model Caja {
  id        Int           @id @default(autoincrement())
  nombre    String        @unique
  pisoId    Int
  estado    GenericStatus @default(ACTIVO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  piso        Piso              @relation(fields: [pisoId], references: [id])
  jornadas    JornadaCaja[]
  sesiones    SesionOperativa[]
  admisiones  Admision[]
  movimientos Movimiento[]
}

model JornadaCaja {
  id                    Int               @id @default(autoincrement())
  cajaId                Int
  fechaOperativa        DateTime
  estado                JornadaCajaEstado @default(ABIERTA)
  baseInicial           Decimal           @db.Decimal(12, 2)
  abiertaPorUsuarioId   Int
  abiertaAt             DateTime
  cerradaPorUsuarioId   Int?
  cerradaAt             DateTime?
  totalCobros           Decimal           @default(0) @db.Decimal(12, 2)
  totalDevoluciones     Decimal           @default(0) @db.Decimal(12, 2)
  saldoEsperado         Decimal           @default(0) @db.Decimal(12, 2)
  efectivoContado       Decimal?          @db.Decimal(12, 2)
  diferenciaCierre      Decimal?          @db.Decimal(12, 2)
  observacionApertura   String?
  observacionCierre     String?
  reabiertaPorUsuarioId Int?
  reabiertaAt           DateTime?
  motivoReapertura      String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  caja                Caja     @relation(fields: [cajaId], references: [id])
  abiertaPorUsuario   Usuario  @relation("JornadaCajaAbiertaPor", fields: [abiertaPorUsuarioId], references: [id])
  cerradaPorUsuario   Usuario? @relation("JornadaCajaCerradaPor", fields: [cerradaPorUsuarioId], references: [id])
  reabiertaPorUsuario Usuario? @relation("JornadaCajaReabiertaPor", fields: [reabiertaPorUsuarioId], references: [id])

  admisiones  Admision[]
  movimientos Movimiento[]
}

model SesionOperativa {
  id               Int                   @id @default(autoincrement())
  usuarioId        Int
  moduloAtencionId Int
  pisoId           Int
  cajaId           Int
  fechaOperativa   DateTime
  horaInicio       DateTime
  horaFin          DateTime?
  estado           SesionOperativaEstado @default(ACTIVA)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  moduloAtencion ModuloAtencion @relation(fields: [moduloAtencionId], references: [id])
  piso           Piso           @relation(fields: [pisoId], references: [id])
  caja           Caja           @relation(fields: [cajaId], references: [id])

  admisiones Admision[]
}

model Admision {
  id                    Int            @id @default(autoincrement())
  consecutivo           Int?           @unique
  fechaHora             DateTime       @default(now())
  pacienteId            Int
  servicioId            Int
  contratoId            Int
  categoriaAfiliacionId Int?
  tipoCobro             TipoCobro
  estado                AdmisionEstado @default(REGISTRADA)
  motivoEstado          String?

  pisoId                 Int
  moduloAtencionId       Int
  cajaId                 Int
  jornadaCajaId          Int
  sesionOperativaId      Int
  registradaPorUsuarioId Int

  pacienteNombreSnapshot            String
  pacienteDocumentoSnapshot         String
  servicioNombreSnapshot            String
  contratoNombreSnapshot            String
  categoriaAfiliacionNombreSnapshot String?
  tipoCobroSnapshot                 TipoCobro
  tarifaIdAplicada                  Int?

  valorBase          Decimal       @db.Decimal(12, 2)
  descuentoTipo      DescuentoTipo @default(NINGUNO)
  descuentoValor     Decimal       @default(0) @db.Decimal(12, 2)
  descuentoCalculado Decimal       @default(0) @db.Decimal(12, 2)
  razonDescuento     String?
  valorFinalCobrado  Decimal       @db.Decimal(12, 2)
  valorRecibido      Decimal       @db.Decimal(12, 2)
  valorDevuelto      Decimal       @default(0) @db.Decimal(12, 2)

  anuladaPorUsuarioId Int?
  anuladaAt           DateTime?
  motivoAnulacion     String?

  metodoPagoSnapshot     MetodoPago?
  referenciaPagoSnapshot String?

  observacion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paciente             Paciente             @relation(fields: [pacienteId], references: [id])
  servicio             Servicio             @relation(fields: [servicioId], references: [id])
  contrato             Contrato             @relation(fields: [contratoId], references: [id])
  categoriaAfiliacion  CategoriaAfiliacion? @relation(fields: [categoriaAfiliacionId], references: [id])
  tarifaAplicada       TarifaServicio?      @relation(fields: [tarifaIdAplicada], references: [id])
  piso                 Piso                 @relation(fields: [pisoId], references: [id])
  moduloAtencion       ModuloAtencion       @relation(fields: [moduloAtencionId], references: [id])
  caja                 Caja                 @relation(fields: [cajaId], references: [id])
  jornadaCaja          JornadaCaja          @relation(fields: [jornadaCajaId], references: [id])
  sesionOperativa      SesionOperativa      @relation(fields: [sesionOperativaId], references: [id])
  registradaPorUsuario Usuario              @relation("AdmisionRegistradaPor", fields: [registradaPorUsuarioId], references: [id])
  anuladaPorUsuario    Usuario?             @relation("AdmisionAnuladaPor", fields: [anuladaPorUsuarioId], references: [id])

  movimientos Movimiento[]

  @@index([fechaHora])
  @@index([pacienteId, fechaHora])
}

model Movimiento {
  id               Int                  @id @default(autoincrement())
  admisionId       Int
  jornadaCajaId    Int
  cajaId           Int
  pisoId           Int
  moduloAtencionId Int
  usuarioId        Int
  tipoMovimiento   MovimientoTipo
  naturaleza       MovimientoNaturaleza
  valor            Decimal              @db.Decimal(12, 2)
  descripcion      String?
  referencia       String?
  metodoPago       MetodoPago           @default(OTRO)
  referenciaPago   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  admision       Admision       @relation(fields: [admisionId], references: [id])
  jornadaCaja    JornadaCaja    @relation(fields: [jornadaCajaId], references: [id])
  caja           Caja           @relation(fields: [cajaId], references: [id])
  piso           Piso           @relation(fields: [pisoId], references: [id])
  moduloAtencion ModuloAtencion @relation(fields: [moduloAtencionId], references: [id])
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([createdAt])
}

model Auditoria {
  id                Int      @id @default(autoincrement())
  usuarioId         Int
  accion            String
  entidad           String
  entidadId         Int
  detalle           String?
  valorAnteriorJson Json?
  valorNuevoJson    Json?
  ip                String?
  createdAt         DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([createdAt])
}

model User {
  id              String    @id
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  username        String?   @unique
  displayUsername String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  accounts        Account[]
  usuario         Usuario?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
